# SLINGSHOT environment — copy to app/.env (git-ignored). Never commit real secrets.
# Prefer GCP Secret Manager in deploy; .env is for local dev only.

# --- Auth backend: AI Studio Gemini API with an API KEY (the approved-models path) ---
GOOGLE_GENAI_USE_VERTEXAI=0
GOOGLE_API_KEY=            # <-- paste your AI Studio (Tier 3 hackathon) key here. NEVER commit it.

# GCP project (used for Secret Manager / deploy; not needed for the API-key path)
GOOGLE_CLOUD_PROJECT=deepmind-hack26blr-4182
GOOGLE_CLOUD_LOCATION=us-central1

# --- Realtime model (approved Live model) ---
DEMO_AGENT_MODEL=gemini-3.1-flash-live-preview

# --- Generated media (NB2 Lite + Omni Flash). Off by default so the demo never blocks. ---
SLINGSHOT_MEDIA=0

# --- NASA NeoWs (live asteroid data). DEMO_KEY works; free key at api.nasa.gov ---
NASA_API_KEY=DEMO_KEY

LOG_LEVEL=INFO
